# ============================================================
# Copy this file to .env and fill in your values
# .env is in .gitignore — NEVER commit it to the repository
# ============================================================

# ── Airflow metadata DB ──────────────────────────────────────
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=change_me_airflow
AIRFLOW_DB_NAME=airflow

# ── Data Warehouse DB ────────────────────────────────────────
DW_USER=mdp
DW_PASSWORD=change_me_dw
DW_DB=mdp_dw

# ── Airflow admin UI user ────────────────────────────────────
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=change_me_admin
AIRFLOW_ADMIN_EMAIL=admin@example.com

# ── dbt (used when running dbt locally, outside Docker) ──────
DBT_HOST=localhost
DBT_PORT=5432
DBT_USER=mdp
DBT_PASSWORD=change_me_dw
DBT_DBNAME=mdp_dw
